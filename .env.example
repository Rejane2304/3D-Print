# Plantilla de variables de entorno para 3D Print

# URL base de la app (usada por NextAuth y metadatos)
NEXTAUTH_URL=http://localhost:3000

# Secreto para firmar JWT de NextAuth
# Genera uno real con:
#   openssl rand -base64 32
NEXTAUTH_SECRET=changeme_nextauth_secret

# Base de datos PostgreSQL usada por Prisma
# Ajusta usuario, password, host y puerto según el entorno
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_3d_print?schema=public

# Claves de Stripe (modo test)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Opcionales para builds personalizados de Next.js
#NEXT_DIST_DIR=.next
#NEXT_OUTPUT_MODE=standalone

