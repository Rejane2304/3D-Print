// ===== IMPRESORAS =====
model Printer {
  id        String   @id @default(cuid())
  name      String
  location  String?
  status    String   @default("available") // available, busy, maintenance
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  orderItems OrderItem[]
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ===== USUARIOS =====
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("user")
  phone         String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  country       String?
  loyaltyPoints Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  cart          Cart?
  orders        Order[]
  reviews       Review[]
  wishlist      Wishlist[]
  pointsHistory PointsTransaction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ===== COLORES =====
model Color {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique // Ej: "Bambu Green", "Pantone 123C"
  hex         String     // #RRGGBB
  image       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  materials   MaterialColor[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

// ===== MATERIALES =====
model Material {
  id                String         @id @default(cuid())
  name              String
  code              String         @unique  // "PLA", "PETG", "ASA", "TPU"
  pricePerKg        Float
  maintenanceFactor Float                   // Factor desgaste USD/hora
  density           Float                   // g/cm³
  description       String?
  inStock           Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  productPrices     ProductPrice[]
  inventory         Inventory?
  cartItems         CartItem[]
  orderItems        OrderItem[]
  colors            MaterialColor[]
}

// Relación N:M Material-Color
model MaterialColor {
  id         String   @id @default(cuid())
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  materialId String
  color      Color    @relation(fields: [colorId], references: [id], onDelete: Cascade)
  colorId    String
  stock      Float    @default(0) // gramos disponibles de ese color/material
  image      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@unique([materialId, colorId])
}

// ===== PRODUCTOS =====
model Product {
  id               String         @id @default(cuid())
  name             String
  description      String         @db.Text
  category         String
  material         String                  // material por defecto (código)
  basePricePerGram Float
  density          Float
  printTimeMinutes Int            @default(90)
  minDimX          Float          @default(10)
  minDimY          Float          @default(10)
  minDimZ          Float          @default(10)
  maxDimX          Float          @default(300)
  maxDimY          Float          @default(300)
  maxDimZ          Float          @default(300)
  defaultDimX      Float          @default(50)
  defaultDimY      Float          @default(50)
  defaultDimZ      Float          @default(50)
  finishCost       Float          @default(2.50)
  modelFillFactor  Float          @default(0.15)  // factor calibrado desde laminador (peso_real / vol_bbox / densidad)
  images           String[]
  featured         Boolean        @default(false)
  stock            Int            @default(100)
  rating           Float          @default(0)
  reviewCount      Int            @default(0)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  cartItems        CartItem[]
  orderItems       OrderItem[]
  reviews          Review[]
  wishlist         Wishlist[]
  prices           ProductPrice[]
}

// ===== PRECIOS CALCULADOS (caché por producto × material) =====
model ProductPrice {
  id              String   @id @default(cuid())
  productId       String
  materialId      String
  materialCost    Float
  machineCost     Float
  maintenanceCost Float
  operationCost   Float
  baseCost        Float
  priceUnit       Float    // 1–4 uds. (margen 250%)
  priceMedium     Float    // 5–9 uds. (margen 200%)
  priceBulk       Float    // 10+ uds. (margen 150%)
  calculatedAt    DateTime @default(now())
  updatedAt       DateTime @updatedAt
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  material        Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  @@unique([productId, materialId])
}

// ===== INVENTARIO (stock por material) =====
model Inventory {
  id         String   @id @default(cuid())
  materialId String   @unique
  quantity   Float                    // gramos disponibles
  minStock   Float    @default(500)   // umbral de alerta
  location   String?
  lastRefill DateTime @default(now())
  updatedAt  DateTime @updatedAt
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
}

// ===== CUPONES =====
model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    // "percentage" | "fixed"
  discountValue Float
  minPurchase   Float?
  maxUses       Int?
  usedCount     Int       @default(0)
  validFrom     DateTime  @default(now())
  validUntil    DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  orders        Order[]
}

// ===== CARRITO =====
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id         String   @id @default(cuid())
  cartId     String
  productId  String
  materialId String?
  colorId    String?
  material   String
  quantity   Int      @default(1)
  dimX       Float
  dimY       Float
  dimZ       Float
  unitPrice  Float
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  materialRef Material? @relation(fields: [materialId], references: [id])
  color      Color?   @relation(fields: [colorId], references: [id])
}

// ===== PEDIDOS =====
model Order {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  printerId       String?
  printer         Printer?  @relation(fields: [printerId], references: [id])
  subtotal        Float
  tax             Float
  shipping        Float
  discount        Float     @default(0)
  total           Float
  status          String    @default("pending")
  stripeSessionId String?   @unique
  couponId        String?
  shippingName    String?
  shippingEmail   String?
  shippingPhone   String?
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  coupon          Coupon?   @relation(fields: [couponId], references: [id])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  materialId String?
  colorId    String?
  name       String
  material   String
  quantity   Int
  dimX       Float
  dimY       Float
  dimZ       Float
  unitPrice  Float
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  materialRef Material? @relation(fields: [materialId], references: [id])
  color      Color?   @relation(fields: [colorId], references: [id])
  printerId  String?
  printer    Printer? @relation(fields: [printerId], references: [id])
}

// ===== RESEÑAS =====
model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String   @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, productId])
}

// ===== OTROS =====
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  status    String   @default("unread")
  createdAt DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, productId])
}

model PointsTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int
  type        String   // "earned", "redeemed", "bonus", "expired"
  description String
  orderId     String?
  createdAt   DateTime @default(now())
}

// ===== CONFIGURACIÓN DE PRECIOS =====
model PricingConfig {
  id                         String   @id @default(cuid())
  machineAmortizationPerHour Float    @default(0.12)
  operationCostPerHour       Float    @default(0.04)
  consumablesCostPerHour     Float    @default(0.02)
  marginUnit                 Float    @default(2.5)
  marginMedium               Float    @default(2.0)
  marginBulk                 Float    @default(1.5)
  updatedAt                  DateTime @updatedAt
}

// ===== ALERTAS ADMIN =====
model Alert {
  id        String   @id @default(cuid())
  type      String   // "stock", "print_queue", "customer_message", "order_issue", "other"
  message   String   @db.Text
  data      String?  // JSON opcional para detalles
  seen      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String?  // Quién generó la alerta (opcional)
  orderId   String?  // Relación con pedido (opcional)
  productId String?  // Relación con producto (opcional)
  materialId String? // Relación con material (opcional)
}
